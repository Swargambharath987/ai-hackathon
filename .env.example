# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_ACTUAL_API_KEY_HERE

# MCP Server ports (used by individual server scripts)
MCP_EPHT_HOST=0.0.0.0
MCP_EPHT_PORT=8889

MCP_OPENDATA_HOST=0.0.0.0
MCP_OPENDATA_PORT=8890

MCP_HEALTHCARE_HOST=0.0.0.0
MCP_HEALTHCARE_PORT=8891

MCP_MEDLINEPLUS_HOST=0.0.0.0
MCP_MEDLINEPLUS_PORT=8892

MCP_OPENFDA_HOST=0.0.0.0
MCP_OPENFDA_PORT=8893

# MCP Server URLs used by fastapi_server.py
# Local dev — defaults below are used automatically, no need to set
# Docker — docker-compose.yml overrides these with service names automatically
MCP_EPHT_URL=http://localhost:8889/sse
MCP_OPENDATA_URL=http://localhost:8890/sse
MCP_HEALTHCARE_URL=http://localhost:8891/sse
MCP_MEDLINEPLUS_URL=http://localhost:8892/sse
MCP_OPENFDA_URL=http://localhost:8893/sse
